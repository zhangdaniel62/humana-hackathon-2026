# Copy to .env and fill in. .env is gitignored; this file is not.
# The agent runs against Gemini in the GADK environment -- these are the values
# that environment supplies.

GOOGLE_API_KEY=your-gemini-api-key-here
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# Optional. Defaults to gemini-flash-latest.
BENEFITS_MODEL=gemini-flash-latest

# Optional. Defaults to <repo root>/datasets, resolved relative to the package.
# BENEFITS_DATASETS_DIR=/absolute/path/to/datasets
