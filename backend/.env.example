# Copy to .env and fill in. .env is gitignored; this file is not.
# The integrated backend uses Vertex AI through Google ADK.

# Optional. Defaults to gemini-flash-latest.
BENEFITS_MODEL=gemini-flash-latest


# --- Data source -----------------------------------------------------------
# csv (default) reads datasets/*.csv: no credentials, no network, cannot fail.
# bigquery loads each table fully into a DataFrame once, at startup.
BENEFITS_DATA_SOURCE=csv

# Required when BENEFITS_DATA_SOURCE=bigquery (startup fails without them).
# BENEFITS_BQ_PROJECT=your-gcp-project
# BENEFITS_BQ_DATASET=your_dataset
# BENEFITS_BQ_LOCATION=US

# Table names, if they differ from the CSV basenames.
# BENEFITS_BQ_COVERAGE_RULES_TABLE=coverage_rules
# BENEFITS_BQ_MEMBERS_TABLE=members
# BENEFITS_BQ_PROVIDERS_TABLE=providers

# If BigQuery is unreachable at startup, fall back to the CSVs (same data) and
# report data_source="csv_fallback" on every answer. Set false to fail loudly.
# BENEFITS_BIGQUERY_FALLBACK_TO_CSV=true

# Optional. Defaults to <repo root>/datasets.
# BENEFITS_DATASETS_DIR=/absolute/path/to/datasets


# --- Core backend service settings ------------------------------------------
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us
GOOGLE_GENAI_USE_VERTEXAI=TRUE
MODEL_NAME=gemini-3.5-flash
LIVE_MODEL_NAME=gemini-live-2.5-flash-native-audio
LIVE_MODEL_LOCATION=us-central1
LIVE_VOICE_NAME=Aoede

BIGQUERY_DATASET=humana_hackathon
BIGQUERY_LOCATION=US

GCS_BUCKET=your-project-id-static-assets-bucket

# --- Local authentication ---------------------------------------------------
# Auth and synthetic operations history share this local runtime SQLite file.
# Generate it from tracked schemas and deterministic seeds with:
# uv run python -m src.operations.bootstrap
AUTH_DATABASE_PATH=.data/auth.sqlite3
AUTH_COOKIE_NAME=claim_assist_session
AUTH_COOKIE_SECURE=false
AUTH_SESSION_TTL_HOURS=8
AUTH_ENABLE_DEMO_SEED=true
# Local testing only. When enabled, cookies are replaced by a synthetic identity.
# Keep disabled outside a developer machine. Use customer or rep to test spoken
# AI output; both Voice-capable roles receive backend audio parity.
AUTH_BYPASS_ENABLED=false
AUTH_BYPASS_ROLE=customer
# Pydantic parses complex environment values as JSON.
AUTH_ALLOWED_ORIGINS=["http://localhost:8000","http://127.0.0.1:8000"]

# --- Sentinel monitoring ----------------------------------------------------
SENTINEL_DENIAL_SPIKE_THRESHOLD=3
SENTINEL_DENIAL_WINDOW_HOURS=24
SENTINEL_ROI_GAP_THRESHOLD=3
SENTINEL_ROI_GAP_RATE_THRESHOLD=0.25
SENTINEL_ROI_MINIMUM_SESSIONS=5
SENTINEL_ROI_WINDOW_HOURS=24
SENTINEL_REPEAT_CONTACT_DAYS=7
SENTINEL_EVIDENCE_LIMIT=25
